{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "25south-booking-form": {
      "projectType": "application",
      "root": "",
      "sourceRoot": "src",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:browser",
          "options": {
            "outputPath":  "dist/25south-booking-form",
            "index":       "src/index.html",
            "main":        "src/main.ts",
            "polyfills":   ["zone.js"],
            "tsConfig":    "tsconfig.app.json",
            "styles":      ["src/styles.scss"],
            "scripts":     [],
            "assets": [
              "src/favicon.ico",
              "src/assets"
            ],
            "outputHashing":     "all",
            "buildOptimizer":    true,
            "optimization":      true,
            "sourceMap":         false,
            "namedChunks":       false,
            "aot":               true,
            "extractLicenses":   true,
            "vendorChunk":       false,
            "commonChunk":       true
          },
          "configurations": {
            "production": {
              "budgets": [
                { "type": "initial",          "maximumWarning": "2mb",  "maximumError": "5mb" },
                { "type": "anyComponentStyle","maximumWarning": "6kb",  "maximumError": "10kb" }
              ],
              "outputHashing": "all",
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with":    "src/environments/environment.prod.ts"
                }
              ]
            },
            "development": {
              "buildOptimizer":  false,
              "optimization":    false,
              "vendorChunk":     true,
              "extractLicenses": false,
              "sourceMap":       true,
              "namedChunks":     true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production":  { "buildTarget": "25south-booking-form:build:production" },
            "development": { "buildTarget": "25south-booking-form:build:development" }
          },
          "defaultConfiguration": "development"
        }
      }
    }
  },
  "cli": {
    "analytics": false
  }
}
